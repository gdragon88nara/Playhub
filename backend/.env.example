# Copy to `.env` and adjust. `.env` is git-ignored.
# ------------------------------------------------------------------
# Core
SECRET_KEY=dev-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Leave DATABASE_URL empty to use SQLite for local dev.
# For Postgres: postgres://user:pass@localhost:5432/gameplatform
DATABASE_URL=

# Redis / Channels
# Leave empty to use the in-memory channel layer (dev only, single process).
# For prod: redis://localhost:6379/0
REDIS_URL=

# CORS / frontend origin
FRONTEND_ORIGIN=http://localhost:3000

# JWT lifetimes (minutes / days)
ACCESS_TOKEN_LIFETIME_MIN=30
REFRESH_TOKEN_LIFETIME_DAYS=7
